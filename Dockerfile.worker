FROM node:22-alpine

WORKDIR /app

# Ghostscript for PDF-to-image conversion
RUN apk add --no-cache ghostscript python3 make g++

COPY package.json pnpm-lock.yaml ./
RUN npm install -g pnpm && pnpm install --frozen-lockfile

COPY . .

RUN pnpm exec prisma generate

# Install tsx for TypeScript worker execution
RUN pnpm add -g tsx

# Entry point dispatches to the right worker based on WORKER_TYPE env
CMD ["sh", "-c", "tsx workers/${WORKER_TYPE}.ts"]
