generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  DELETED
}

enum ShareStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum AuditAction {
  DOCUMENT_VIEWED
  DOCUMENT_DOWNLOADED
  DOCUMENT_PRINTED
  PAGE_VIEWED
  SHARE_CREATED
  SHARE_REVOKED
  ACCESS_GRANTED
  ACCESS_DENIED
  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  SESSION_STARTED
  SESSION_ENDED
  SUSPICIOUS_ACTIVITY
  UPLOAD_STARTED
  UPLOAD_COMPLETED
  DOCUMENT_DELETED
  SETTINGS_CHANGED
}

enum SuspiciousEventType {
  MULTIPLE_OTP_FAILURES
  UNUSUAL_IP
  RAPID_PAGE_VIEWS
  SCREENSHOT_ATTEMPT
  DEVTOOLS_DETECTED
  MULTIPLE_SESSIONS
  EXPIRED_ACCESS_ATTEMPT
  REVOKED_ACCESS_ATTEMPT
  RATE_LIMIT_HIT
}

enum NotificationType {
  DOCUMENT_VIEWED
  SHARE_EXPIRING
  SUSPICIOUS_ACTIVITY
  ACCESS_REVOKED
  NEW_VIEWER_ONLINE
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  passwordHash     String
  role             UserRole @default(USER)
  emailVerified    Boolean  @default(false)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  avatarUrl        String?
  storageUsed      BigInt   @default(0)
  storageLimit     BigInt   @default(5368709120)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  documents     Document[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("UserAuditLogs")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String
  userAgent    String
  deviceId     String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
}

model OtpCode {
  id          String   @id @default(cuid())
  email       String
  code        String
  purpose     String
  shareId     String?
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  isUsed      Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

// ─── Document Models ──────────────────────────────────────────────────────────

model Document {
  id               String         @id @default(cuid())
  userId           String
  title            String
  description      String?
  originalFilename String
  mimeType         String
  fileSize         BigInt
  pageCount        Int            @default(0)
  status           DocumentStatus @default(PENDING)
  storageKey       String
  encryptionKeyId  String?
  checksum         String?
  virusScanPassed  Boolean?
  thumbnailKey     String?
  tags             String[]       @default([])
  isPublic         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  pages     DocumentPage[]
  shares    Share[]
  auditLogs AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

model DocumentPage {
  id         String   @id @default(cuid())
  documentId String
  pageNumber Int
  storageKey String
  width      Int
  height     Int
  fileSize   Int
  isRendered Boolean  @default(false)
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([documentId])
}

// ─── Sharing Models ───────────────────────────────────────────────────────────

model Share {
  id          String      @id @default(cuid())
  documentId  String
  createdById String
  token       String      @unique
  status      ShareStatus @default(ACTIVE)

  requiresOtp    Boolean  @default(false)
  allowedEmails  String[] @default([])
  allowedIps     String[] @default([])
  allowDownload  Boolean  @default(false)
  allowPrint     Boolean  @default(false)
  allowCopy      Boolean  @default(false)
  showWatermark  Boolean  @default(true)

  expiresAt      DateTime?
  maxViews       Int?
  currentViews   Int      @default(0)

  recipientName  String?
  recipientEmail String?
  message        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revokedAt DateTime?

  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipients Recipient[]
  accessLogs AuditLog[]

  @@index([documentId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

model Recipient {
  id            String    @id @default(cuid())
  shareId       String
  email         String
  name          String?
  hasViewed     Boolean   @default(false)
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())

  share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@unique([shareId, email])
  @@index([shareId])
  @@index([email])
}

// ─── Audit & Monitoring ───────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  userId     String?
  documentId String?
  shareId    String?
  ipAddress  String
  userAgent  String
  country    String?
  city       String?
  deviceId   String?
  sessionId  String?
  pageNumber Int?
  duration   Int?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user     User?     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  share    Share?    @relation(fields: [shareId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([shareId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([ipAddress])
}

model SuspiciousEvent {
  id         String              @id @default(cuid())
  type       SuspiciousEventType
  shareId    String?
  documentId String?
  ipAddress  String
  userAgent  String
  email      String?
  details    Json
  resolved   Boolean             @default(false)
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())

  @@index([type])
  @@index([shareId])
  @@index([documentId])
  @@index([resolved])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
