# ─── Application ────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://vaultix.yourdomain.com

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultix:CHANGE_ME@postgres:5432/vaultix

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT Secrets (generate with: openssl rand -hex 64) ───────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64_HEX_CHARS

# ─── Encryption (generate with: openssl rand -hex 32) ────────
# Must be exactly 64 hex characters (32 bytes for AES-256)
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_64_CHARS

# ─── S3 / MinIO ──────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=vaultix_admin
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET
S3_BUCKET=vaultix-documents

# ─── SMTP (Email) ────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=Vaultix <noreply@yourdomain.com>
